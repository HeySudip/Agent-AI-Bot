# =============================================================================
# Required
# =============================================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# =============================================================================
# Optional — runtime behavior
# =============================================================================

# Logical environment name. Used in logs / metrics. Use "prod" in production.
ENVIRONMENT=dev

# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_FORMAT: json (recommended for production) | console (pretty for dev)
LOG_FORMAT=

# Agent loop guardrails
MAX_TOOL_ITERATIONS=10
SHORT_TERM_MEMORY_SIZE=30
MAX_INPUT_CHARS=8000

# Rate limiting (per Telegram user_id)
RATE_LIMIT_BURST=5
RATE_LIMIT_BURST_WINDOW_S=10
RATE_LIMIT_SUSTAINED=40
RATE_LIMIT_SUSTAINED_WINDOW_S=300

# HTTP client behaviour
HTTP_TIMEOUT_S=20
FETCH_URL_MAX_CHARS=10000

# Storage paths (relative to my-agent/)
DATABASE_PATH=data.db
CONFIG_PATH=config/config.json

# =============================================================================
# Provider API keys
# =============================================================================
#
# All provider keys are normally set by pasting them directly to the bot in
# Telegram chat — they are detected and saved to config/config.json. You can
# also pre-populate them via env vars below; values here will seed the JSON
# config on first start.
#
#   GEMINI_API_KEY=AIzaSy...
#   ANTHROPIC_API_KEY=sk-ant-...
#   GITHUB_TOKEN=ghp_...
#   TAVILY_API_KEY=tvly-...
#   GROQ_API_KEY=gsk_...
#   GROK_API_KEY=xai-...
#   HUGGINGFACE_API_KEY=hf_...
#   OPENROUTER_API_KEY=sk-or-v1-...
